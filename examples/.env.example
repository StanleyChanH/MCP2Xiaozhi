# Xiaozhi WebSocket endpoint for the bridge.
# Get this from your Xiaozhi server's MCP configuration page.
MCP_ENDPOINT=wss://api.your-xiaozhi-server.example/mcp/YOUR_TOKEN

# Optional: per-server endpoints (NAME uppercased, non-alphanumeric -> _).
# MCP_ENDPOINT_LOCAL_STDIO_CALCULATOR=wss://.../mcp/token-a
# MCP_ENDPOINT_REMOTE_HTTP_SERVER=wss://.../mcp/token-b

# Optional: override the default config file location.
# MCP_CONFIG=./mcp_config.json

# Optional: logging verbosity.
# MCP2XIAOZHI_LOG_LEVEL=INFO
